# Volunteer mirror configuration. Copy to `.env` and edit before running
# `docker compose up -d`. Both values are optional — leave blank for a
# local-only test stack (HTTP on :80, no public federation).

# Public hostname your VPS serves on (DNS A/AAAA record must point here).
# Setting this triggers:
#   - Caddy auto-provisions a Let's Encrypt TLS certificate for this host
#   - Kubo configures path-mode gateway so /ipfs/<CID> works on your domain
#   - The mirror daemon advertises wss://<host>/relay so other mirrors
#     discover your relay automatically (set MIRROR_RELAY_URL too)
MIRROR_HOST=

# Optional contact email for Let's Encrypt expiry notifications.
ACME_EMAIL=

# Public WSS URL of this mirror's bundled strfry relay. Visitors discover
# this from your heartbeat events and add it to their relay query pool.
# Typically: wss://<MIRROR_HOST>/relay
MIRROR_RELAY_URL=

# ISO country code (e.g. IN, DE, US) reported in heartbeats — purely
# informational, helps visitors see geographic distribution of mirrors.
COUNTRY=
